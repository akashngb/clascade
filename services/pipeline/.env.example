# SlideQuest generation pipeline — environment template.
# Copy this file to `.env` (which is git-ignored) and fill in real values.
# NEVER paste a private key into chat, commit it, or hardcode it in source.

# --- Vertex AI (GCP) ---
# Path to a service-account JSON key file, OR the JSON inline (single line).
# Prefer GOOGLE_APPLICATION_CREDENTIALS pointing at a file outside the repo.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/rotated-service-account.json
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1

# --- Poly Pizza (3D asset library) ---
# Only needed if you fetch new models at build time; the runtime does not use it.
POLY_PIZZA_API_KEY=your-poly-pizza-key
