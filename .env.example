# Vertex AI. Keep the JSON on one line and never commit the real value.
GOOGLE_SERVICE_ACCOUNT_JSON=
GCP_PROJECT=your-project-id
GCP_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash

# Poly Pizza is used only from server routes.
POLY_PIZZA_API_KEY=

# ---- Live classroom sync (teacher controls student phase) ----
# Durable session store for the teacher→student phase sync. REQUIRED in
# production on serverless (Vercel/Netlify): without it, teacher and students
# hit different instances and desync. Vercel KV and Upstash Redis both expose
# this same REST API — create one, then paste its URL + token here.
# (Leave blank for local dev or a single always-on Node host: an in-memory
# store is used automatically.)
KV_REST_API_URL=
KV_REST_API_TOKEN=
